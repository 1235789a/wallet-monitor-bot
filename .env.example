# ============================================================
# Whale Tracker TG Bot · 环境变量配置模板
# 复制本文件为 .env 后填入你自己的值：  cp .env.example .env
# ============================================================

# ---------- 必填 ----------

# Telegram Bot Token（从 @BotFather 用 /newbot 获取）
TG_BOT_TOKEN=your_bot_token_here

# 代理：国内网络无法直连 Telegram，必须填本地代理（Clash 默认 7890）。
# 海外服务器可留空直连。支持 http:// 或 socks5://
TG_PROXY=http://127.0.0.1:7890

# 你的 USDT 收款地址（推荐 Tron TRC20，手续费低）
PAYOUT_WALLET=你的收款地址

# ---------- 强烈建议填 ----------

# 链上 API Key（不填对应链扫描会失败或被限流）
TRONGRID_API_KEY=          # https://www.trongrid.io
ETHERSCAN_API_KEY=         # https://etherscan.io/apis
BSCSCAN_API_KEY=           # https://bscscan.com/apis

# 管理员 Telegram ID（多个用英文逗号分隔），用于 /broadcast 群发
# 用 @userinfobot 查询你自己的数字 ID
ADMIN_USER_IDS=

# ---------- 可选：运营参数（不填则用默认值）----------

# 收款链（默认 tron）
PAYOUT_CHAIN=tron

# 定价
PRICE_USDT=5               # 月费 USDT
TRIAL_DAYS=3               # 免费试用天数
SUBSCRIPTION_DAYS=30       # 付费有效期天数

# 监控参数
CHECK_INTERVAL_MINUTES=10  # 鲸鱼扫描轮询间隔（分钟）
FREE_WALLET_LIMIT=3        # 免费版可追踪地址数
PAID_WALLET_LIMIT=50       # 付费版可追踪地址数
MIN_USD_VALUE=1000         # 最低推送金额（美元）

# 聪明钱 / Alpha 参数
SMART_MONEY_CHAINS=ethereum,bsc,tron
SMART_USD_THRESHOLD=5000   # 聪明钱更新热度的最低 USD 阈值
DIGEST_HOUR_UTC=12         # 每日日报推送时间（UTC 小时）
HEAT_TOP_N=10              # 热度榜 Top N

# 数据库路径（默认 whale_tracker.db）
DATABASE_PATH=whale_tracker.db
